# Populates active_file (~497 MiB) for ~30s; writable mmap + write-touch keeps pages on active list.
command_for_local_exec = "dd if=/dev/zero of=/tmp/active_big bs=1M count=497 2>/dev/null; python3 -c 'import mmap, time\nwith open(\"/tmp/active_big\", \"r+b\") as f:\n m=mmap.mmap(f.fileno(), 0, access=mmap.ACCESS_WRITE)\n end=time.time()+30\n while time.time()<end:\n  for i in range(0, len(m), 4096): m[i]=m[i]'"
